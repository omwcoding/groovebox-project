# Mint - Configurazione Variabili di Ambiente (Esempio)
# ==============================================================================
# Istruzioni: Copiare questo file rinominandolo in .env ed inserire la propria SECRET_KEY.

# Chiave segreta per la firma e cifratura dei token JWT (sostituire in produzione)
SECRET_KEY=inserisci_qui_la_tua_chiave_segreta_lunga_e_casuale

# Credenziali per l'integrazione con le API di Discogs
DISCOGS_CONSUMER_KEY=inserisci_qui_la_tua_consumer_key
DISCOGS_CONSUMER_SECRET=inserisci_qui_la_tua_consumer_secret

# Configurazione Database PostgreSQL e API Supabase
DATABASE_URL=postgresql://postgres.[username]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_ANON_KEY=eyJ...

# Password per gli utenti di default del seeding (admin e test)
# Se lasciate vuote o omesse, verranno usate rispettivamente 'admin' e 'test'
SEED_ADMIN_PASSWORD=admin
SEED_TEST_PASSWORD=test

# Domini abilitati per CORS. Lasciare commentato o vuoto in sviluppo locale (applicherà il fallback automatico per localhost)
ALLOWED_ORIGINS=https://mint.tuodominio.com

