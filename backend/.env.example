# GrooveBox - Configurazione Variabili di Ambiente (Esempio)
# ==============================================================================
# Istruzioni: Copiare questo file rinominandolo in .env ed inserire la propria SECRET_KEY.

# Chiave segreta per la firma e cifratura dei token JWT (sostituire in produzione)
SECRET_KEY=inserisci_qui_la_tua_chiave_segreta_lunga_e_casuale

# Credenziali per l'integrazione con le API di Discogs
DISCOGS_CONSUMER_KEY=inserisci_qui_la_tua_consumer_key
DISCOGS_CONSUMER_SECRET=inserisci_qui_la_tua_consumer_secret

